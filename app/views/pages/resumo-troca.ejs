<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Resumo de Troca - CPC</title>
  <link rel="stylesheet" href="/css/resumo-troca.css">
  <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Poppins:wght@400;600;700&display=swap">
</head>

<%- include('../partials/header.ejs') %>
<body>
  <main>
    <header class="page-header">
      <h1>Resumo de Troca</h1>
    </header>

    <% if (!anuncio) { %>
      <p style="text-align:center;padding:40px">Nenhum anúncio selecionado. <a href="/todos">Ver anúncios</a></p>
    <% } else { %>

    <section class="trade-info">
      <dl class="trade-details">
        <dt>Anúncio:</dt>
        <dd><%= anuncio.titulo %></dd>
        <dt>Doador:</dt>
        <dd><%= anuncio.doadorNome %> — <%= anuncio.doadorLocal %></dd>
        <dt>Pontos:</dt>
        <dd><%= anuncio.pontos %> PONTOS</dd>
        <dt>Tipo:</dt>
        <dd><%= anuncio.tipo === 'servico' ? 'Serviço' : 'Produto' %></dd>
      </dl>
    </section>

    <section class="calculation-section">
      <h2>Valor estimado</h2>
      <article class="calculation-details">
        <p class="calculation-formula"><%= anuncio.pontos %> PONTOS</p>
        <p class="calculation-conversion"><%= anuncio.pontos %> × 5 = R$ <%= (anuncio.pontos * 5).toFixed(2) %></p>
        <p class="calculation-final">R$ <%= (anuncio.pontos * 5).toFixed(2) %> - Taxa = <strong>R$ <%= (anuncio.pontos * 5 * 0.9).toFixed(2) %></strong></p>
      </article>
    </section>

    <section class="products-showcase">
      <figure class="product-images">
        <img src="<%= anuncio.foto %>" alt="<%= anuncio.titulo %>" class="product-image">
        <span class="exchange-symbol" aria-hidden="true">⇄</span>
        <img src="../img/leite.webp" alt="Produto em troca" class="product-image">
      </figure>
    </section>

    <section class="trade-description">
      <p><%= anuncio.descricao %></p>
    </section>

    <section class="terms-section">
      <p class="terms-text">
        Ao fazer essa troca você concorda com os
        <a href="#" class="terms-link">Termos de uso do Conexão por Créditos</a>.
      </p>
    </section>

    <!-- Formulário de confirmação - registra no banco -->
    <section class="action-section">
      <form action="/confirmar-troca" method="POST">
        <input type="hidden" name="anuncioId" value="<%= anuncio.id %>">
        <input type="hidden" name="anuncioTitulo" value="<%= anuncio.titulo %>">
        <textarea name="mensagem" placeholder="Mensagem para o doador (opcional)" style="width:100%;padding:12px;border-radius:8px;border:1px solid #ccc;margin-bottom:12px;font-family:Poppins,sans-serif;font-size:14px;resize:vertical" rows="3"></textarea>
        <button type="submit" class="confirm-button">Confirmar Troca</button>
      </form>

      <aside class="warning-notice">
        <p>Os usuários têm até 30 dias para efetuar os serviços. Ao realizar a troca você concorda com todos os termos de uso da plataforma e com o Contrato de troca.</p>
      </aside>
    </section>

    <% } %>
  </main>
</body>
<br><br><br>
<%- include('../partials/footer.ejs') %>
</html>
