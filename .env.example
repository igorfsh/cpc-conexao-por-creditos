# Exemplo de arquivo de variáveis de ambiente
# Copie este arquivo para .env e preencha seus valores locais.

EMAIL_USER=seu_email@example.com
EMAIL_PASS=sua_senha_de_aplicativo

APP_PORT=3000
PORT=3000

DB_HOST=localhost
DB_USER=root
DB_PASSWORD=
DB_NAME=cpc
DB_CONNECTION_LIMIT=10

SESSION_SECRET=um_valor_forte_e_unico_em_producao

NODE_ENV=development

# Google OAuth
GOOGLE_CLIENT_ID=seu_google_client_id_aqui
GOOGLE_CLIENT_SECRET=seu_google_client_secret_aqui
GOOGLE_CALLBACK_URL=http://localhost:3000/auth/google/callback

# GitHub OAuth
GITHUB_CLIENT_ID=seu_github_client_id_aqui
GITHUB_CLIENT_SECRET=seu_github_client_secret_aqui
GITHUB_CALLBACK_URL=http://localhost:3000/auth/github/callback
